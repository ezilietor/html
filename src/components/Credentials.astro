---
import { education, certifications, profile } from '../data/profile.js';
import SealIcon from './SealIcon.astro';
---
<section id="credenciales" class="section">
  <div class="wrap">
    <p class="eyebrow eyebrow--on-paper">
      <span data-i18n="es">Registro 04</span><span data-i18n="en">Entry 04</span>
    </p>
    <div class="section-head">
      <h2><span data-i18n="es">Credenciales</span><span data-i18n="en">Credentials</span></h2>
      <a class="btn btn--ink" href={profile.social.linkedin} target="_blank" rel="noopener noreferrer">
        <span data-i18n="es">Ver perfil de LinkedIn</span><span data-i18n="en">View LinkedIn profile</span> ↗
      </a>
    </div>

    <div class="credentials-grid">
      <div>
        <h3 class="credentials-subtitle">
          <span data-i18n="es">Formación académica</span><span data-i18n="en">Education</span>
        </h3>
        <ul class="timeline">
          {education.map((item) => (
            <li class="timeline__item">
              <span class="timeline__dot" aria-hidden="true"></span>
              <div>
                <p class="timeline__degree">
                  <span data-i18n="es">{item.degree.es}</span>
                  <span data-i18n="en">{item.degree.en}</span>
                </p>
                <p class="timeline__institution">{item.institution}</p>
                <span class="tag timeline__status">
                  <span data-i18n="es">{item.status.es}</span>
                  <span data-i18n="en">{item.status.en}</span>
                </span>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="credentials-subtitle">
          <span data-i18n="es">Certificaciones y cursos</span><span data-i18n="en">Certifications & courses</span>
        </h3>
        <ul class="cert-list">
          {certifications.map((cert) => (
            <li class="card cert-card">
              <SealIcon size={40} />
              <div>
                <p class="cert-card__title">
                  <span data-i18n="es">{cert.title.es}</span>
                  <span data-i18n="en">{cert.title.en}</span>
                </p>
                <p class="cert-card__issuer">{cert.issuer}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .credentials-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-5);
  }

  .credentials-subtitle {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    margin-bottom: var(--space-3);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .timeline__item {
    display: flex;
    gap: var(--space-2);
    position: relative;
    padding-left: var(--space-1);
  }

  .timeline__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-brass);
    margin-top: 0.45em;
    flex-shrink: 0;
  }

  .timeline__degree {
    font-weight: 600;
    color: var(--color-ink);
  }

  .timeline__institution {
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    margin-top: 0.2em;
  }

  .timeline__status {
    display: inline-block;
    margin-top: 0.5em;
  }

  .cert-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cert-card {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
  }

  .cert-card__title {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-ink);
  }

  .cert-card__issuer {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-ink-soft);
    margin-top: 0.2em;
  }

  @media (max-width: 860px) {
    .credentials-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
</style>
