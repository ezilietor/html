---
import { profile } from '../data/profile.js';

const buildDate = new Date().toLocaleDateString('es-DO', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<footer id="contacto" class="footer">
  <div class="wrap footer__inner">
    <div class="footer__main">
      <p class="eyebrow">
        <span data-i18n="es">Registro 05 — Contacto</span><span data-i18n="en">Entry 05 — Contact</span>
      </p>
      <h2 class="footer__title">
        <span data-i18n="es">Hablemos.</span><span data-i18n="en">Let's talk.</span>
      </h2>
      <p class="footer__text">
        <span data-i18n="es">
          Disponible para colaboraciones, prácticas o cualquier proyecto relacionado con seguridad informática.
        </span>
        <span data-i18n="en">
          Open to collaborations, internships, or any project related to information security.
        </span>
      </p>
      <a class="btn btn--solid footer__email" href={`mailto:${profile.email}`}>
        {profile.email}
      </a>
    </div>

    <ul class="footer__links">
      <li><a href={profile.social.github} target="_blank" rel="noopener noreferrer">GitHub ↗</a></li>
      <li><a href={profile.social.youtube} target="_blank" rel="noopener noreferrer">YouTube ↗</a></li>
      <li><a href={profile.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn ↗</a></li>
    </ul>
  </div>

  <div class="wrap footer__bottom">
    <span>{profile.location}</span>
    <span class="footer__sync">
      <span data-i18n="es">Última sincronización:</span><span data-i18n="en">Last synced:</span> {buildDate}
    </span>
    <span>© {new Date().getFullYear()} {profile.name}</span>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-navy);
    color: var(--color-paper-raised);
    padding: var(--space-6) 0 var(--space-3);
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .footer__main {
    max-width: 480px;
  }

  .footer__title {
    margin-top: var(--space-1);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    color: var(--color-paper-raised);
  }

  .footer__text {
    margin-top: var(--space-2);
    color: rgba(251, 247, 236, 0.78);
    line-height: 1.6;
  }

  .footer__email {
    margin-top: var(--space-3);
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .footer__links a {
    color: var(--color-paper-raised);
    text-decoration: none;
    opacity: 0.8;
  }

  .footer__links a:hover {
    opacity: 1;
    color: var(--color-coral-soft);
  }

  .footer__bottom {
    margin-top: var(--space-5);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-navy-line);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: rgba(251, 247, 236, 0.55);
  }
</style>
