---
import LangToggle from './LangToggle.astro';
---
<header class="site-header">
  <div class="wrap site-header__inner">
    <a href="#inicio" class="brand">
      <svg width="28" height="28" viewBox="0 0 64 64" fill="none" aria-hidden="true">
        <circle cx="32" cy="32" r="30" fill="var(--color-brass)" />
        <path d="M20 33 L27.5 40.5 L45 22" stroke="var(--color-navy)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
      </svg>
      <span class="brand__text">EJ<span class="brand__dot">.</span>log</span>
    </a>

    <nav class="site-nav" aria-label="Navegación principal">
      <a href="#sobre-mi">
        <span data-i18n="es">Sobre mí</span><span data-i18n="en">About</span>
      </a>
      <a href="#proyectos">
        <span data-i18n="es">Proyectos</span><span data-i18n="en">Projects</span>
      </a>
      <a href="#videos">Videos</a>
      <a href="#credenciales">
        <span data-i18n="es">Credenciales</span><span data-i18n="en">Credentials</span>
      </a>
      <a href="#contacto">
        <span data-i18n="es">Contacto</span><span data-i18n="en">Contact</span>
      </a>
    </nav>

    <LangToggle variant="on-navy" />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-navy);
    border-bottom: 1px solid var(--color-navy-line);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-top: var(--space-2);
    padding-bottom: var(--space-2);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    text-decoration: none;
    color: var(--color-paper-raised);
    flex-shrink: 0;
  }

  .brand__text {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    letter-spacing: 0.02em;
  }

  .brand__dot {
    color: var(--color-coral-bright);
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .site-nav a {
    color: var(--color-paper-raised);
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }

  .site-nav a:hover {
    opacity: 1;
    color: var(--color-brass-soft);
  }

  @media (max-width: 720px) {
    .site-header__inner {
      flex-wrap: wrap;
      row-gap: var(--space-1);
    }
    .site-nav {
      order: 3;
      width: 100%;
      gap: var(--space-2);
      font-size: 0.76rem;
    }
  }
</style>
