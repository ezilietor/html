---
import { profile } from '../data/profile.js';
---
<section id="inicio" class="hero">
  <div class="wrap hero__inner">
    <p class="eyebrow">
      <span data-i18n="es">Bitácora digital — entrada 00</span>
      <span data-i18n="en">Digital logbook — entry 00</span>
    </p>

    <h1 class="hero__name">{profile.name}</h1>

    <p class="hero__role">
      <span data-i18n="es">{profile.role.es}</span>
      <span data-i18n="en">{profile.role.en}</span>
    </p>

    <p class="hero__tagline">
      <span data-i18n="es">{profile.tagline.es}</span>
      <span data-i18n="en">{profile.tagline.en}</span>
    </p>

    <div class="hero__meta">
      <span class="hero__meta-item">📍 {profile.location}</span>
    </div>

    <div class="hero__actions">
      <a class="btn btn--solid" href="#proyectos">
        <span data-i18n="es">Ver proyectos</span><span data-i18n="en">View projects</span>
      </a>
      <a class="btn btn--ghost" href="#credenciales">
        <span data-i18n="es">Ver credenciales</span><span data-i18n="en">View credentials</span>
      </a>
    </div>

    <ul class="hero__socials">
      <li>
        <a href={profile.social.github} target="_blank" rel="noopener noreferrer">GitHub ↗</a>
      </li>
      <li>
        <a href={profile.social.youtube} target="_blank" rel="noopener noreferrer">YouTube ↗</a>
      </li>
      <li>
        <a href={profile.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
      </li>
    </ul>
  </div>
</section>

<style>
  .hero {
    background: var(--color-navy);
    color: var(--color-paper-raised);
    padding: var(--space-6) 0 var(--space-5);
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(circle at 1px 1px, rgba(185, 136, 42, 0.16) 1px, transparent 0);
    background-size: 26px 26px;
    opacity: 0.5;
  }

  .hero__inner {
    position: relative;
    max-width: 760px;
  }

  .hero__name {
    margin-top: var(--space-2);
    font-size: clamp(2.3rem, 6vw, 3.6rem);
    color: var(--color-paper-raised);
  }

  .hero__role {
    margin-top: var(--space-1);
    font-family: var(--font-mono);
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    color: var(--color-brass-soft);
  }

  .hero__tagline {
    margin-top: var(--space-3);
    font-size: 1.1rem;
    max-width: 56ch;
    color: rgba(251, 247, 236, 0.85);
  }

  .hero__meta {
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: rgba(251, 247, 236, 0.65);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .hero__socials {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-navy-line);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .hero__socials a {
    color: var(--color-paper-raised);
    text-decoration: none;
    opacity: 0.8;
  }

  .hero__socials a:hover {
    opacity: 1;
    color: var(--color-coral-soft);
  }
</style>
