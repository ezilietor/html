---
interface Props {
  variant?: 'on-navy' | 'on-paper';
}
const { variant = 'on-navy' } = Astro.props;
---
<div class={`lang-toggle lang-toggle--${variant}`} role="group" aria-label="Idioma / Language">
  <button type="button" data-lang-toggle data-lang-value="es" aria-pressed="true">
    ES
  </button>
  <span class="lang-toggle__sep" aria-hidden="true">/</span>
  <button type="button" data-lang-toggle data-lang-value="en" aria-pressed="false">
    EN
  </button>
</div>

<style>
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
  }

  .lang-toggle button {
    background: none;
    border: 1px solid transparent;
    padding: 0.3em 0.55em;
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: inherit;
    transition: opacity 0.15s ease, border-color 0.15s ease;
    opacity: 0.55;
  }

  .lang-toggle button[aria-pressed='true'] {
    opacity: 1;
  }

  .lang-toggle--on-navy button {
    color: var(--color-paper-raised);
  }
  .lang-toggle--on-navy button[aria-pressed='true'] {
    border-color: var(--color-brass);
  }

  .lang-toggle--on-paper button {
    color: var(--color-ink);
  }
  .lang-toggle--on-paper button[aria-pressed='true'] {
    border-color: var(--color-coral);
  }

  .lang-toggle__sep {
    opacity: 0.35;
  }
</style>
