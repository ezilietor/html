---
import { GITHUB_PROFILE_URL } from '../lib/github.js';

interface Repo {
  name: string;
  description: string | null;
  url: string;
  homepage: string | null;
  stars: number;
  language: string | null;
  topics: string[];
  updatedAt: string;
}

interface Props {
  repos: Repo[];
}
const { repos } = Astro.props;

function formatDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString('es-DO', { year: 'numeric', month: 'short' });
}
---
<section id="proyectos" class="section">
  <div class="wrap">
    <p class="eyebrow eyebrow--on-paper">
      <span data-i18n="es">Registro 02</span><span data-i18n="en">Entry 02</span>
    </p>
    <div class="section-head">
      <h2><span data-i18n="es">Proyectos</span><span data-i18n="en">Projects</span></h2>
      <a class="btn btn--ink" href={GITHUB_PROFILE_URL} target="_blank" rel="noopener noreferrer">
        <span data-i18n="es">Ver todo en GitHub</span><span data-i18n="en">View all on GitHub</span> ↗
      </a>
    </div>

    {repos.length > 0 ? (
      <div class="repo-grid">
        {repos.map((repo) => (
          <a class="card repo-card" href={repo.url} target="_blank" rel="noopener noreferrer">
            <div class="repo-card__top">
              <h3 class="repo-card__name">{repo.name}</h3>
              {repo.stars > 0 && <span class="repo-card__stars">★ {repo.stars}</span>}
            </div>
            <p class="repo-card__desc">
              {repo.description || (
                <>
                  <span data-i18n="es">Sin descripción todavía.</span>
                  <span data-i18n="en">No description yet.</span>
                </>
              )}
            </p>
            <div class="repo-card__footer">
              {repo.language && <span class="tag">{repo.language}</span>}
              <span class="repo-card__date">{formatDate(repo.updatedAt)}</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty-state">
        <span data-i18n="es">
          No se pudieron cargar los repositorios en este momento. Visítalos directamente en
        </span>
        <span data-i18n="en">
          Repositories couldn't be loaded right now. Visit them directly on
        </span>{' '}
        <a href={GITHUB_PROFILE_URL} target="_blank" rel="noopener noreferrer">GitHub ↗</a>
      </p>
    )}
  </div>
</section>

<style>
  .repo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-3);
  }

  .repo-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .repo-card__top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .repo-card__name {
    font-family: var(--font-mono);
    font-size: 1.02rem;
    color: var(--color-navy);
    word-break: break-word;
  }

  .repo-card__stars {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-brass);
    white-space: nowrap;
  }

  .repo-card__desc {
    font-size: 0.92rem;
    color: var(--color-ink-soft);
    flex-grow: 1;
    line-height: 1.55;
  }

  .repo-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .repo-card__date {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--color-ink-soft);
  }

  .empty-state {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--color-ink-soft);
  }

  .empty-state a {
    color: var(--color-coral);
  }
</style>
