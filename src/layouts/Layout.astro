---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ezequiel Jiménez Rodríguez — Seguridad Informática',
  description = 'Portafolio de Ezequiel Jiménez Rodríguez, estudiante de Tecnología en Seguridad Informática. Proyectos, certificaciones y videos.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es" data-lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Public+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!--
      Inicializa el idioma ANTES del primer pintado para evitar parpadeo.
      Por defecto el sitio se renderiza en español; aquí lo sobrescribimos
      si el visitante ya eligió "en" antes, o si su navegador está en inglés.
    -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('lang');
          var lang =
            stored ||
            (navigator.language && navigator.language.toLowerCase().startsWith('en') ? 'en' : 'es');
          document.documentElement.setAttribute('data-lang', lang);
          document.documentElement.setAttribute('lang', lang);
        } catch (e) {
          /* localStorage no disponible: se queda en español por defecto */
        }
      })();
    </script>
  </head>
  <body>
    <slot />

    <script>
      function initLangToggle() {
        const html = document.documentElement;
        const buttons = document.querySelectorAll('[data-lang-toggle]');

        function applyLang(lang) {
          html.setAttribute('data-lang', lang);
          html.setAttribute('lang', lang);
          buttons.forEach((btn) => {
            const isActive = btn.getAttribute('data-lang-value') === lang;
            btn.setAttribute('aria-pressed', String(isActive));
          });
          try {
            localStorage.setItem('lang', lang);
          } catch (e) {
            /* no-op */
          }
        }

        buttons.forEach((btn) => {
          btn.addEventListener('click', () => {
            applyLang(btn.getAttribute('data-lang-value'));
          });
        });

        // sincroniza el estado visual de los botones con el idioma ya aplicado
        applyLang(html.getAttribute('data-lang') || 'es');
      }

      initLangToggle();
    </script>
  </body>
</html>
