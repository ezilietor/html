---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import Videos from '../components/Videos.astro';
import Credentials from '../components/Credentials.astro';
import Footer from '../components/Footer.astro';
import { getGithubRepos } from '../lib/github.js';
import { getYoutubeVideos } from '../lib/youtube.js';

// Estos fetch corren en build-time (en el runner de GitHub Actions),
// no en el navegador del visitante. Si una API falla, cada lib devuelve
// un arreglo vacío y el componente correspondiente muestra un respaldo.
const [repos, videos] = await Promise.all([getGithubRepos(), getYoutubeVideos()]);
---
<Layout>
  <Header />
  <Hero />
  <main>
    <About />
    <Projects repos={repos} />
    <Videos videos={videos} />
    <Credentials />
  </main>
  <Footer />
</Layout>
